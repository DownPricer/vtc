# API centrale (Express) — calcul tarif, devis, réservation, contact
NEXT_PUBLIC_API_URL=http://localhost:4000
NEXT_PUBLIC_TENANT_ID=default

# URL publique du site (canonique, liens)
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# DistanceMatrix.ai — utilisé uniquement par l’API centrale (plus par le frontend)
# DISTANCE_MATRIX_API_KEY=

# --- SMTP (OVH, Zimbra, etc.) ---
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=0
SMTP_USER=
SMTP_PASS=
MAIL_FROM=
MAIL_TO=
